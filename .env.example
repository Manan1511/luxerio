VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_public_storefront_token
VITE_SHOPIFY_API_VERSION=2024-10
VITE_GA4_ID=

# Netlify Functions only — NEVER exposed to the browser
SHOPIFY_SHOP_DOMAIN=luxerio-62.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=
# Admin API client-credentials grant — the function fetches a short-lived
# access token itself (see netlify/functions/lib/shopify.js) rather than
# using a fixed static token, since this app type's tokens expire in ~24h.
SHOPIFY_ADMIN_CLIENT_ID=
SHOPIFY_ADMIN_CLIENT_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
